PORT=5001
MONGO_URI=your_mongodb_connection_string_here

STEAM_API_KEY=your_stream_api_key_here
STEAM_API_SECRET=your_stream_api_secret_here

JWT_SECRET_KEY=your_secure_jwt_secret_key_here
NODE_ENV=development

# DeepL Translation API (Opcional - usa MyMemory como fallback)
# DEEPL_API_KEY=your_deepl_api_key_here

# Azure Speech Service para Transcrição (Opcional)
# AZURE_SPEECH_KEY=your_azure_speech_key_here
# AZURE_SPEECH_REGION=your_azure_region_here

# LibreTranslate (Opcional - usa instância pública por padrão)
# LIBRETRANSLATE_URL=https://libretranslate.com
# Se quiser usar sua própria instância do LibreTranslate:
# LIBRETRANSLATE_URL=http://localhost:5000
